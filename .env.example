# Database
DATABASE_URL=postgresql+asyncpg://pos_user:pos_password@postgres:5432/pos_db
DATABASE_URL_SYNC=postgresql://pos_user:pos_password@postgres:5432/pos_db

# JWT Auth
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# App
APP_NAME=RetailPOS
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000

# Postgres
POSTGRES_USER=pos_user
POSTGRES_PASSWORD=pos_password
POSTGRES_DB=pos_db

# Azure Blob Storage Backup
AZURE_STORAGE_ACCOUNT=your_storage_account_name
AZURE_STORAGE_KEY=your_storage_account_key
AZURE_STORAGE_CONTAINER=pos-backups
HEALTHCHECKS_PING_URL=https://hc-ping.com/your-uuid-here
